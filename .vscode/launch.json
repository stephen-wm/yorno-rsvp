{
  "version": "0.2.0",
  "configurations": [
    {
      // Attach the VS Code debugger to the running Next.js dev server.
      // Start the server with `npm run dev` first, then launch this config.
      // Set breakpoints in Server Components, server actions, and API routes.
      "name": "Next.js: debug server-side",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true
    },
    {
      // Debug client-side code directly in VS Code via the Chrome debugger.
      // Requires the app to already be running on localhost:3000.
      "name": "Next.js: debug client-side",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "sourceMaps": true
    },
    {
      // Full-stack debug: launches the Next.js dev server with the Node
      // inspector flag enabled and attaches both server and client debuggers.
      "name": "Next.js: debug full stack",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/next",
      "args": ["dev", "--inspect"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "started server on .+, url: (https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome",
        "killOnServerStop": true,
        "webRoot": "${workspaceFolder}"
      },
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "env": {
        "NODE_OPTIONS": "--inspect"
      }
    }
  ]
}
