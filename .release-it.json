{
	"$schema": "https://unpkg.com/release-it/schema/release-it.json",
	"git": {
		"commitMessage": "chore(release): v${version} [skip ci]",
		"tagName": "v${version}",
		"tagAnnotation": "Release v${version}",
		"requireBranch": "main",
		"requireCleanWorkingDir": true,
		"push": true
	},
	"github": {
		"release": true,
		"releaseName": "v${version}",
		"autoGenerate": false,
		"tokenRef": "GITHUB_TOKEN"
	},
	"npm": {
		"publish": false
	},
	"plugins": {
		"@release-it/keep-a-changelog": {
			"filename": "CHANGELOG.md",
			"addUnreleased": true,
			"addVersionUrl": true,
			"versionUrlFormat": "https://github.com/stephen-wm/yorno-rsvp/compare/v{previousTag}...v{tag}",
			"unreleasedUrlFormat": "https://github.com/stephen-wm/yorno-rsvp/compare/v{tag}...HEAD",
			"keepUnreleasedSection": true,
			"strictLatest": true
		}
	}
}
